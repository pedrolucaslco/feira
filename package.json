{
  "name": "feira",
  "version": "0.0.0",
  "private": true,
  "description": "PWA offline-first para lista de mercado e orçamento mensal.",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "npm run build:css && vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "typecheck": "node -e \"console.log('TypeScript ainda nao esta configurado neste PWA estatico.')\"",
    "build:css": "tailwindcss -i ./src/app.css -o ./assets/app.css --minify",
    "watch:css": "tailwindcss -i ./src/app.css -o ./assets/app.css --watch"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.87.1",
    "lucide-react": "^0.554.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.16",
    "@tailwindcss/vite": "^4.1.16",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "daisyui": "^5.5.5",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.13"
  },
  "engines": {
    "node": ">=20"
  }
}
